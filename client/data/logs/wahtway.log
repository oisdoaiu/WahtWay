{"ts":"2026-07-16 00:07:21.742","lv":"INFO","mod":"agent","tid":"d2e0e652","evt":"tool_call","tool":"write-file","args":{"content":"/**\n * 暴力对拍代码 — 邻接表 + DFS\n * 用于验证 LCT 正解的正确性\n * \n * 每次 query 都从 root 开始 DFS 计算子树大小\n * 复杂度 O(n) per query，适用于小数据对拍\n */\n\n#include <bits/stdc++.h>\nusing namespace std;\n\nconst int MAXN = 100005;\nvector<int> adj[MAXN];\nint sub_sz[MAXN];\nint n, m;\n\n// 从 root 开始 DFS，建立以 root 为根的树并计算子树大小\nvoid dfs(int u, int p) {\n    sub_sz[u] = 1;\n    for (int v : adj[u]) {\n        if (v == p) continue;\n        dfs(v, u);\n        sub_sz[u] += sub_sz[v];\n    }\n}\n\n// 添加边\nvoid link(int u, int v) {\n    adj[u].push_back(v);\n    adj[v].push_back(u);\n}\n\n// 删除边\nvoid cut(int u, int v) {\n    auto it = find(adj[u].begin(), adj[u].end(), v);\n    if (it != adj[u].end()) adj[u].erase(it);\n    it = find(adj[v].begin(), adj[v].end(), u);\n    if (it != adj[v].end()) adj[v].erase(it);\n}\n\n// 查询：以 root 为根时，u 的子树大小\nint query(int u, int root) {\n    dfs(root, 0);        // 从 root 开始 DFS 建树\n    return sub_sz[u];    // 返回 u 的子树大小\n}\n\nint main() {\n    ios::sync_with_stdio(false);\n    cin.tie(nullptr);\n\n    cin >> n >> m;\n    for (int i = 1; i <= n; i++) adj[i].clear();\n\n    while (m--) {\n        string op;\n        int u, v;\n        cin >> op >> u >> v;\n\n        if (op == \"link\") {\n            link(u, v);\n        } else if (op == \"cut\") {\n            cut(u, v);\n        } else if (op == \"query\") {\n            cout << query(u, v) << '\\n';\n        }\n    }\n\n    return 0;\n}\n","path":"F:\\作业\\大二下\\中软\\test\\brute.cpp"}}
