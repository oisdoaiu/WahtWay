{"ts":"2026-07-16 00:07:05.434","lv":"INFO","mod":"agent","tid":"d2e0e652","evt":"tool_call","tool":"write-file","args":{"content":"/**\n * LCT 维护子树大小 — 正解模板\n * 题目：动态森林中的子树大小查询\n * \n * 核心技巧：\n *   sz[x]  = Splay 子树总大小（实+虚+自己）\n *   vsz[x] = 所有虚儿子的子树大小之和\n *   pushup: sz[x] = sz[lc] + sz[rc] + vsz[x] + 1\n *   在 access 中维护 vsz（虚实切换时更新）\n */\n\n#include <bits/stdc++.h>\nusing namespace std;\n\nconst int MAXN = 100005;\n\nstruct LinkCutTree {\n    int ch[MAXN][2], fa[MAXN], rev[MAXN];\n    int sz[MAXN];   // Splay 子树总大小\n    int vsz[MAXN];  // 虚子树大小之和\n\n    // ---------- 初始化 ----------\n    void init(int n) {\n        for (int i = 1; i <= n; i++) {\n            ch[i][0] = ch[i][1] = fa[i] = rev[i] = 0;\n            sz[i] = 1;\n            vsz[i] = 0;\n        }\n    }\n\n    // ---------- pushup ----------\n    // 核心公式：总大小 = 左 + 右 + 虚子树 + 自己\n    void pushup(int x) {\n        sz[x] = sz[ch[x][0]] + sz[ch[x][1]] + vsz[x] + 1;\n    }\n\n    // ---------- pushdown：翻转标记 ----------\n    void pushdown(int x) {\n        if (!rev[x]) return;\n        int lc = ch[x][0], rc = ch[x][1];\n        if (lc) { swap(ch[lc][0], ch[lc][1]); rev[lc] ^= 1; }\n        if (rc) { swap(ch[rc][0], ch[rc][1]); rev[rc] ^= 1; }\n        rev[x] = 0;\n    }\n\n    // ---------- 判断 x 是否是 Splay 的根 ----------\n    bool isroot(int x) {\n        return ch[fa[x]][0] != x && ch[fa[x]][1] != x;\n    }\n\n    // ---------- 旋转 ----------\n    void rotate(int x) {\n        int y = fa[x], z = fa[y];\n        int k = (ch[y][1] == x);\n        if (!isroot(y)) ch[z][ch[z][1] == y] = x;\n        fa[x] = z;\n        ch[y][k] = ch[x][k ^ 1];\n        if (ch[x][k ^ 1]) fa[ch[x][k ^ 1]] = y;\n        ch[x][k ^ 1] = y;\n        fa[y] = x;\n        pushup(y);\n        pushup(x);\n    }\n\n    // ---------- splay：把 x 旋转到所在 Splay 的根 ----------\n    int stk[MAXN];\n    void splay(int x) {\n        int top = 0, y = x;\n        stk[++top] = y;\n        while (!isroot(y)) {\n            y = fa[y];\n            stk[++top] = y;\n        }\n        while (top) pushdown(stk[top--]);\n\n        while (!isroot(x)) {\n            int y = fa[x], z = fa[y];\n            if (!isroot(y)) {\n                if ((ch[y][1] == x) ^ (ch[z][1] == y)) rotate(x);\n                else rotate(y);\n            }\n            rotate(x);\n        }\n    }\n\n    // ---------- access：核心！虚实切换时维护 vsz ----------\n    // 把 x 到根的路径变成实链，并断开 x 下方的实边\n    void access(int x) {\n        for (int y = 0; x; y = x, x = fa[x]) {\n            splay(x);\n            // 旧右儿子变成虚儿子 → vsz 增加\n            if (ch[x][1]) vsz[x] += sz[ch[x][1]];\n            // y 从虚儿子变成实儿子 → vsz 减少\n            ch[x][1] = y;\n            if (y) vsz[x] -= sz[y];\n            pushup(x);\n        }\n    }\n\n    // ---------- makeroot：把 x 变成原树的根 ----------\n    void makeroot(int x) {\n        access(x);\n        splay(x);\n        swap(ch[x][0], ch[x][1]);\n        rev[x] ^= 1;\n    }\n\n    // ---------- findroot：找到 x 所在原树的根 ----------\n    int findroot(int x) {\n        access(x);\n        splay(x);\n        while (ch[x][0]) {\n            pushdown(x);\n            x = ch[x][0];\n        }\n        splay(x);\n        return x;\n    }\n\n    // ---------- link：连边 (x, y)，x 成为 y 的父节点 ----------\n    void link(int x, int y) {\n        makeroot(x);\n        if (findroot(y) != x) {\n            access(y);\n            splay(y);\n            fa[y] = x;           // y → x 是虚边\n            vsz[x] += sz[y];     // x 的虚子树大小增加\n            pushup(x);\n        }\n    }\n\n    // ---------- cut：断边 (x, y) ----------\n    void cut(int x, int y) {\n        makeroot(x);\n        access(y);\n        splay(y);\n        // 此时 y 的左儿子一定是 x（且 x 没有右儿子）\n        if (ch[y][0] == x && !ch[x][1]) {\n            ch[y][0] = fa[x] = 0;\n            pushup(y);\n        }\n    }\n\n    // ---------- 查询：以 root 为根时，u 的子树大小 ----------\n    int query(int u, int root) {\n        makeroot(root);     // 让 root 成为整棵树的根\n        access(u);          // 打通 u 到 root 的路径\n        splay(u);\n        // access 后 u 没有实儿子（下方被断开），子树 = vsz[u] + 1\n        return vsz[u] + 1;\n    }\n} lct;\n\nint main() {\n    ios::sync_with_stdio(false);\n    cin.tie(nullptr);\n\n    int n, m;\n    cin >> n >> m;\n    lct.init(n);\n\n    while (m--) {\n        string op;\n        int u, v;\n        cin >> op >> u >> v;\n\n        if (op == \"link\") {\n            lct.link(u, v);\n        } else if (op == \"cut\") {\n            lct.cut(u, v);\n        } else if (op == \"query\") {\n            // query u root: 查询以 v 为根时 u 的子树大小\n            cout << lct.query(u, v) << '\\n';\n        }\n    }\n\n    return 0;\n}\n","path":"F:\\作业\\大二下\\中软\\test\\lct_template.cpp"}}
